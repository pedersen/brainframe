# Flutter's per-platform runner projects are generated by `flutter create`.
# Mark them as generated so GitHub collapses them in diffs and excludes them
# from language statistics. Hand-edited values in these trees (e.g. the
# bundle identifier) are reviewed when changed, not on every PR.
android/**  linguist-generated=true
ios/**      linguist-generated=true
macos/**    linguist-generated=true
linux/**    linguist-generated=true
windows/**  linguist-generated=true
web/**      linguist-generated=true
