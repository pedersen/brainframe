# Claude Code worktrees live here; never track them.
.claude/worktrees/

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# VS Code Counter extension output (line-count reports); a local analysis
# artifact, not part of the project.
.VSCodeCounter/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# The in-repo custom_lint plugin (tool/lints) is a library package, so its
# lockfile is regenerated by `dart pub get`, not committed — only the root
# application pubspec.lock is tracked.
/tool/lints/pubspec.lock

# Generated localizations (gen-l10n output). Derived from lib/l10n/*.arb and
# regenerated by the build (pubspec `generate: true`); never committed.
/lib/l10n/gen/

# Coverage output. The generated test/coverage/all_files_test.dart is tracked;
# the measured lcov traces are build artifacts.
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
