  "settingsEngramThemeDesc": "Override the theme just for the current engram.",
  "@settingsEngramThemeDesc": {
    "description": "Description under the per-engram theme override setting."
  },

  "settingsThemeFollowDefault": "Default",
  "@settingsThemeFollowDefault": {
