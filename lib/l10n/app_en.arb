  "settingsThemeDark": "Dark",
  "@settingsThemeDark": {
    "description": "Color-scheme option: always use the dark theme."
  },

  "settingsAboutDesc": "Version, license, and links.",
  "@settingsAboutDesc": {
    "description": "Subtitle of the About settings category (used as the sidebar/category description)."
  },

  "settingsHousekeepingName": "Housekeeping",
  "@settingsHousekeepingName": {
    "description": "Name of the Housekeeping settings category (maintenance jobs on engrams), shown in the sidebar and as the pane heading."
  },

  "settingsHousekeepingDesc": "Maintenance jobs for your engrams.",
  "@settingsHousekeepingDesc": {
    "description": "Subtitle of the Housekeeping settings category, shown under its name in the sidebar."
  },

  "housekeepingIntro": "Forgetting an engram removes it from BrainFrame and the switcher. Its folder and files are left on disk — nothing is deleted.",
  "@housekeepingIntro": {
    "description": "Explanatory text at the top of the Housekeeping pane, clarifying that forgetting never deletes files."
  },

  "housekeepingEmpty": "Nothing to forget. Only engrams you've added from a folder can be forgotten.",
  "@housekeepingEmpty": {
    "description": "Shown in the Housekeeping pane when there are no forgettable engrams (ones added from a folder)."
  },

  "housekeepingMissing": "Missing",
  "@housekeepingMissing": {
    "description": "Badge on a Housekeeping row whose engram folder no longer resolves (a dangling entry)."
  },

  "housekeepingForget": "Forget",
  "@housekeepingForget": {
    "description": "Button that removes an engram from BrainFrame's registry (leaving its files); also the confirm-dialog action label."
  },

  "housekeepingConfirmTitle": "Forget “{name}”?",
  "@housekeepingConfirmTitle": {
    "description": "Title of the confirmation dialog before forgetting an engram.",
    "placeholders": {
      "name": { "type": "String", "example": "Field Notebook" }
    }
  },

  "housekeepingConfirmBody": "This removes it from BrainFrame. Its files stay on disk, untouched.",
  "@housekeepingConfirmBody": {
    "description": "Body of the confirmation dialog before forgetting an engram."
