{
  "@@locale": "en",

  "appTitle": "BrainFrame",
  "@appTitle": {
    "description": "The application's name, shown as the window/task title. A proper noun — translators normally leave it as \"BrainFrame\"."
  },

  "startupOpening": "Opening BrainFrame",
  "@startupOpening": {
    "description": "Screen-reader label for the launch spinner shown while the initial engram is resolving."
  },

  "startupOpenError": "Could not open your engrams.",
  "@startupOpenError": {
    "description": "Message shown when the app fails to resolve any engram at startup."
  },

  "switcherCurrentEngram": "Current engram {name}. Switch engram",
  "@switcherCurrentEngram": {
    "description": "Accessibility label for the sidebar-footer button that opens the engram switcher.",
    "placeholders": {
      "name": { "type": "String", "example": "Personal" }
    }
  },

  "switcherReadOnly": "Read-only",
  "@switcherReadOnly": {
    "description": "Accessibility label on the lock icon marking the current engram as read-only (e.g. a built-in engram)."
  },

  "switcherHeading": "Engrams",
  "@switcherHeading": {
    "description": "Heading at the top of the engram switcher sheet, above the list of engrams."
  },

  "switcherUnavailable": "Unavailable — reconnect coming soon",
  "@switcherUnavailable": {
    "description": "Subtitle on a switcher row for an engram whose folder could not be resolved; reconnecting is not yet implemented."
  },

  "switcherNewEngram": "New engram",
  "@switcherNewEngram": {
    "description": "Label for the action that creates a new engram — used both as the switcher row and the create-dialog title."
  },

  "switcherOpenFolder": "Open folder…",
  "@switcherOpenFolder": {
    "description": "Switcher action (desktop only) that opens an existing folder as an engram. The trailing ellipsis signals a dialog follows."
  },

  "newEngramNameLabel": "Name",
  "@newEngramNameLabel": {
    "description": "Text-field label in the new-engram dialog, where the user types the engram's name."
  },

  "cancel": "Cancel",
  "@cancel": {
    "description": "Generic dialog button that dismisses without acting."
  },

  "create": "Create",
  "@create": {
    "description": "Confirm button in the new-engram dialog that creates the engram."
  },

  "helpTitle": "Help",
  "@helpTitle": {
    "description": "The help feature's name — the app-bar action tooltip, the help overlay's header, and the built-in help engram's name in the switcher."
  },

  "tutorialTitle": "Tutorial",
  "@tutorialTitle": {
    "description": "The built-in tutorial engram's name, shown in the engram switcher."
  },

  "helpIndex": "Index",
  "@helpIndex": {
    "description": "Button in the help overlay that returns to the help index from a sub-page."
  },

  "helpClose": "Close help",
  "@helpClose": {
    "description": "Tooltip on the button that closes the help overlay."
  },

  "browserLoading": "Loading engram",
  "@browserLoading": {
    "description": "Screen-reader label for the spinner shown while the active engram's files are loading."
  },

  "browserUnreadable": "Could not read this engram.",
  "@browserUnreadable": {
    "description": "Message shown in the reader pane when the active engram's file list cannot be read."
  },

  "engramEmpty": "This engram has no files yet.",
  "@engramEmpty": {
    "description": "Empty-state message shown when an engram contains no visible files (in both the file tree and the reader pane)."
  },

  "browserSelectFile": "Select a file to read it.",
  "@browserSelectFile": {
    "description": "Prompt shown in the reader pane when the engram has files but none is selected."
  },

  "menuOpenBrowser": "Open file browser",
  "@menuOpenBrowser": {
    "description": "Tooltip on the phone-layout menu button that opens the file-browser drawer."
  },

  "drawerCloseBrowser": "Close file browser",
  "@drawerCloseBrowser": {
    "description": "Accessibility label on the scrim that closes the file-browser drawer when tapped."
  },

  "resizeHandleLabel": "Resize file browser",
  "@resizeHandleLabel": {
    "description": "Accessibility label for the draggable divider that resizes the sidebar."
  },

  "resizeHandleWidth": "{width} pixels wide",
  "@resizeHandleWidth": {
    "description": "Screen-reader value announcing the sidebar's current width for the resize slider.",
    "placeholders": {
      "width": { "type": "int", "example": "260" }
    }
  },

  "fileTreeFolder": "Folder {name}",
  "@fileTreeFolder": {
    "description": "Accessibility label for a folder row in the file tree.",
    "placeholders": {
      "name": { "type": "String", "example": "notes" }
    }
  },

  "fileTreeFile": "File {name}",
  "@fileTreeFile": {
    "description": "Accessibility label for a file row in the file tree.",
    "placeholders": {
      "name": { "type": "String", "example": "welcome.md" }
    }
  },

  "readerLoading": "Loading file",
  "@readerLoading": {
    "description": "Screen-reader label for the spinner shown while a file's contents load in the reader."
  },

  "readerFilePath": "File path: {path}",
  "@readerFilePath": {
    "description": "Accessibility label for the file-path breadcrumb above the rendered markdown.",
    "placeholders": {
      "path": { "type": "String", "example": "notes/first-note.md" }
    }
  },

  "readerOpenError": "Could not open “{path}”.",
  "@readerOpenError": {
    "description": "Message shown in the reader when a selected file cannot be read.",
    "placeholders": {
      "path": { "type": "String", "example": "notes/first-note.md" }
    }
  },

  "viewerImageLabel": "Image {name}",
  "@viewerImageLabel": {
    "description": "Screen-reader label describing the rendered image in the viewer, since the file itself carries no alt text.",
    "placeholders": {
      "name": { "type": "String", "example": "diagram.png" }
    }
  },

  "viewerUnsupportedFormat": "Can’t display “{name}” yet.",
  "@viewerUnsupportedFormat": {
    "description": "Message shown in the viewer when the selected file's format is recognized but has no viewer yet (e.g. PDF, EPUB).",
    "placeholders": {
      "name": { "type": "String", "example": "book.epub" }
    }
  },

  "viewerImageActualSize": "View at full size",
  "@viewerImageActualSize": {
    "description": "Tooltip and screen-reader label for the image-viewer button that switches from the scaled-to-fit view to the image's actual pixel size (with scroll bars)."
  },

  "viewerImageFitToWindow": "Fit image to window",
  "@viewerImageFitToWindow": {
    "description": "Tooltip and screen-reader label for the image-viewer button that switches from the actual-size view back to scaling the whole image to fit the pane."
  },

  "markdownEditorLabel": "Markdown editor",
  "@markdownEditorLabel": {
    "description": "Screen-reader label for the plain-text Markdown source editor (a multiline text field where the user types raw Markdown)."
  },

  "editorModeGroupLabel": "Editing mode",
  "@editorModeGroupLabel": {
    "description": "Screen-reader label for the Edit/Preview toggle group in the Markdown editor header."
  },

  "editorModeEdit": "Edit",
  "@editorModeEdit": {
    "description": "Label for the toggle segment that shows the raw Markdown source editor."
  },

  "editorModePreview": "Preview",
  "@editorModePreview": {
    "description": "Label for the toggle segment that shows the rendered Markdown preview."
  },

  "saveStatusSaved": "Saved",
  "@saveStatusSaved": {
    "description": "Save-status chip: the file is saved and matches what is on disk."
  },

  "saveStatusSaving": "Saving…",
  "@saveStatusSaving": {
    "description": "Save-status chip: a write to disk is in progress."
  },

  "saveStatusUnsaved": "Unsaved changes",
  "@saveStatusUnsaved": {
    "description": "Save-status chip: the buffer has edits not yet written to disk."
  },

  "saveStatusError": "Couldn’t save",
  "@saveStatusError": {
    "description": "Save-status chip: the last write to disk failed; edits are kept for retry."
  },

  "saveNowTooltip": "Save now",
  "@saveNowTooltip": {
    "description": "Tooltip and screen-reader hint for tapping the save-status chip to flush edits to disk immediately."
  },

  "newNote": "New note",
  "@newNote": {
    "description": "Tooltip and dialog title for creating a new Markdown note in the current engram."
  },

  "newNoteNameLabel": "Note name",
  "@newNoteNameLabel": {
    "description": "Text-field label in the new-note dialog where the user types the note's name."
  },

  "newFolder": "New folder",
  "@newFolder": {
    "description": "Tooltip and dialog title for creating a new folder in the current engram."
  },

  "newFolderNameLabel": "Folder name",
  "@newFolderNameLabel": {
    "description": "Text-field label in the new-folder dialog where the user types the folder's name."
  },

  "rowActionsTooltip": "Actions for {name}",
  "@rowActionsTooltip": {
    "description": "Tooltip and screen-reader label for a file-tree row's \"⋯\" action-menu button.",
    "placeholders": {
      "name": { "type": "String", "example": "welcome.md" }
    }
  },

  "rename": "Rename",
  "@rename": {
    "description": "Row-action menu item, and title of the rename dialog, for renaming a file or folder."
  },

  "renameNameLabel": "New name",
  "@renameNameLabel": {
    "description": "Text-field label in the rename dialog where the user types the new name."
  },

  "delete": "Delete",
  "@delete": {
    "description": "Row-action menu item, and confirm button, for deleting a file or folder."
  },

  "deleteConfirmTitle": "Delete?",
  "@deleteConfirmTitle": {
    "description": "Title of the confirmation dialog shown before deleting a file or folder."
  },

  "deleteFileConfirm": "Delete “{name}”? This can’t be undone.",
  "@deleteFileConfirm": {
    "description": "Confirmation message before deleting a single file.",
    "placeholders": {
      "name": { "type": "String", "example": "welcome.md" }
    }
  },

  "deleteFolderConfirm": "Delete “{name}” and everything in it? This can’t be undone.",
  "@deleteFolderConfirm": {
    "description": "Confirmation message before deleting a folder and all its contents.",
    "placeholders": {
      "name": { "type": "String", "example": "notes" }
    }
  },

  "move": "Move",
  "@move": {
    "description": "Row-action menu item, and confirm button in the folder picker, for moving a file or folder to another folder."
  },

  "moveTitle": "Move to…",
  "@moveTitle": {
    "description": "Title of the folder-picker dialog shown when moving a file or folder."
  },

  "folderPickerRoot": "Top level",
  "@folderPickerRoot": {
    "description": "Folder-picker entry for the engram's root (top level, no parent folder)."
  },

  "folderPickerEmpty": "No other folder to move to.",
  "@folderPickerEmpty": {
    "description": "Shown in the folder picker when there is nowhere else to move the item."
  },

  "aboutTitle": "About",
  "@aboutTitle": {
    "description": "Title of the About screen (app-bar heading), which shows the app identity, version, and contact links."
  },

  "aboutTagline": "Your personal knowledge management system — capture, connect, and recall everything you know.",
  "@aboutTagline": {
    "description": "One-line description of the app shown under its name on the About screen."
  },

  "aboutBuild": "build",
  "@aboutBuild": {
    "description": "The word 'build' in the version pill 'v2.4.1 · build 1847', preceding the build number. Kept separate so only the linguistic word is translated; the 'v' prefix, separator, and numbers are not."
  },

  "aboutVersionSemantics": "Version {version}, build {build}",
  "@aboutVersionSemantics": {
    "description": "Screen-reader label for the version pill, which visually reads 'v{version} · build {build}'.",
    "placeholders": {
      "version": { "type": "String", "example": "2.4.1" },
      "build": { "type": "String", "example": "1847" }
    }
  },

  "aboutWebsiteLabel": "Website",
  "@aboutWebsiteLabel": {
    "description": "Uppercase label above the website link on the About screen's links card."
  },

  "aboutWebsiteValue": "brainframe.tech",
  "@aboutWebsiteValue": {
    "description": "Display text of the website link (the project's domain). A brand/address constant — translators normally leave it unchanged."
  },

  "aboutContactLabel": "Contact",
  "@aboutContactLabel": {
    "description": "Uppercase label above the contact (email) link on the About screen's links card."
  },

  "aboutContactValue": "getbrainframe@gmail.com",
  "@aboutContactValue": {
    "description": "Display text of the contact email link. An address constant — translators normally leave it unchanged."
  },

  "aboutFooter": "© {year} BrainFrame · Made for minds that never stop.",
  "@aboutFooter": {
    "description": "Footer line at the bottom of the About screen. {year} is the copyright span: the founding year alone (e.g. '2026') or a range once the calendar advances (e.g. '2026–2028').",
    "placeholders": {
      "year": { "type": "String", "example": "2026–2028" }
    }
  },

  "settingsTitle": "Settings",
  "@settingsTitle": {
    "description": "Title of the Settings screen (app-bar heading and the sidebar header), and the phone back-button label."
  },

  "settingsTooltip": "Settings",
  "@settingsTooltip": {
    "description": "Tooltip / accessibility label for the app-bar button that opens the Settings screen."
  },

  "settingsSearchPlaceholder": "Search all settings…",
  "@settingsSearchPlaceholder": {
    "description": "Placeholder text in the settings sidebar search field."
  },

  "settingsGroupCore": "Core",
  "@settingsGroupCore": {
    "description": "Sidebar group header for the app's built-in settings categories (shown uppercased)."
  },

  "settingsGroupPlugins": "Plugins",
  "@settingsGroupPlugins": {
    "description": "Sidebar group header for settings categories contributed by plugins (shown uppercased)."
  },

  "settingsAppearanceName": "Appearance",
  "@settingsAppearanceName": {
    "description": "Name of the Appearance settings category (theme and interface look)."
  },

  "settingsAppearanceDesc": "Theme and interface look.",
  "@settingsAppearanceDesc": {
    "description": "Subtitle of the Appearance settings category, shown under its name in the detail pane."
  },

  "settingsSectionTheme": "Theme",
  "@settingsSectionTheme": {
    "description": "Section header within Appearance for theme (light/dark) settings."
  },

  "settingsDefaultTheme": "Default theme",
  "@settingsDefaultTheme": {
    "description": "Setting row label for the device-wide default theme (light/dark/system)."
  },

  "settingsDefaultThemeDesc": "Used everywhere unless an engram overrides it.",
  "@settingsDefaultThemeDesc": {
    "description": "Description under the Default theme setting."
  },

  "settingsEngramTheme": "This engram",
